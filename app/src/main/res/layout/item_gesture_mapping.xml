<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardUseCompatPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <!-- 手势图标/emoji -->
        <TextView
            android:id="@+id/tv_gesture_icon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:textSize="24sp"
            android:background="@drawable/overlay_border"
            android:text="🖐️" />

        <!-- 手势名称 + 描述 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp">

            <TextView
                android:id="@+id/tv_gesture_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="手势名称"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_gesture_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="手势描述"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- 操作选择 -->
        <Spinner
            android:id="@+id/spinner_action"
            android:layout_width="120dp"
            android:layout_height="40dp"
            android:background="@drawable/overlay_border"
            android:padding="8dp"
            android:popupBackground="@color/surface"
            android:dropDownSelector="@color/surface" />

        <!-- 单条重置 -->
        <ImageButton
            android:id="@+id/btn_reset_single"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="?attr/actionModeUndoDrawable"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="恢复默认"
            app:tint="@color/text_secondary"
            android:layout_marginStart="4dp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
