<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <!-- 标题区域 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🖐️ 手势控制"
        android:textSize="28sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginTop="40dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="用手势操控抖音"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="48dp" />

    <!-- 状态卡片 -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="服务状态"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <!-- 服务状态行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <View
                    android:id="@+id/indicator_service"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/circle_green"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="手势识别"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:id="@+id/tv_service_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_stopped"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <!-- 悬浮窗权限行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/circle_accent"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/permission_overlay"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:id="@+id/tv_overlay_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✗ 未授权"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <!-- 摄像头权限行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/circle_accent"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/permission_camera"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:id="@+id/tv_camera_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✗ 未授权"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <!-- 无障碍权限行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/circle_accent"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="无障碍服务"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:id="@+id/tv_accessibility_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✗ 未开启"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 操作按钮区域 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_toggle"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/start_service"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="28dp"
        android:layout_marginBottom="16dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_config"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/open_config"
        android:textSize="16sp"
        app:cornerRadius="28dp"
        android:layout_marginBottom="24dp" />

    <!-- 权限提示 -->
    <LinearLayout
        android:id="@+id/layout_permissions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp"
        android:background="@drawable/overlay_border"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠️ 需要开启以下权限才能使用"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_overlay_permission"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/permission_overlay"
                android:textSize="11sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_accessibility"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/open_accessibility"
                android:textSize="11sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_camera_permission"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/permission_camera"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 手势说明 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="💡 使用方法：\n\n1. 确保三项权限都已授权\n2. 点「自定义手势」→ 为每个操作录制对应手势\n3. 返回主界面 → 启动手势识别\n4. 打开抖音，在摄像头前做已录制的手势即可控制"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:lineSpacingExtra="2dp"
        android:layout_marginTop="16dp" />

</LinearLayout>
